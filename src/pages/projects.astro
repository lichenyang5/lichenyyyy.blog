---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, getPostsByTag } from '../utils/posts';
import { SOCIAL } from '../consts';

const posts = await getPublishedPosts();

interface ProjectLink {
  label: string;
  href: string;
}
interface Project {
  name: string;
  summary: string;
  stack: string[];
  links: ProjectLink[];
  /** 用标签把相关文章关联进来 */
  relatedTag?: string;
  placeholder?: boolean;
}

// TODO: 把 href 占位换成真实仓库地址
const projects: Project[] = [
  {
    name: 'harmony-chat-demo',
    summary: 'HarmonyOS AI 聊天 Demo：从一句话意图出发，跑通后端流式、前端状态、结构化卡片与本地持久化。',
    stack: ['ArkUI', 'SSE', '结构化卡片', 'RDB 持久化', '状态机', '调试面板'],
    links: [{ label: 'GitHub', href: `${SOCIAL.github}` }],
    relatedTag: 'SSE',
  },
  {
    name: 'harmony-ASCF-demo',
    summary: 'ASCF Web 容器与 JSBridge Demo：把 H5 嵌进鸿蒙，并搭一套双向桥，复刻「前端只认 API、底座按 action 给能力」。',
    stack: ['WebView', 'JSBridge', 'Bridge 协议', '能力分发', '容器治理'],
    links: [{ label: 'GitHub', href: `${SOCIAL.github}` }],
    relatedTag: 'Web容器',
  },
  {
    name: 'harmony-learning-notes',
    summary: 'HarmonyOS 学习日报：记录从 ArkUI 基础到工程实践的学习过程。',
    stack: ['ArkUI', 'ArkTS', '工程化'],
    links: [{ label: 'GitHub', href: `${SOCIAL.github}` }],
    relatedTag: '模块化',
  },
  {
    name: '壁纸小程序',
    summary: '早期做过的微信小程序项目。占位，后续补充。',
    stack: ['微信小程序'],
    links: [],
    placeholder: true,
  },
];

const withRelated = projects.map((p) => ({
  ...p,
  related: p.relatedTag ? getPostsByTag(posts, p.relatedTag).slice(0, 3) : [],
}));
---

<BaseLayout title="项目" description="做过的几个项目，以及相关文章。">
  <header class="page-head">
    <h1 class="page-title">项目</h1>
    <p class="page-sub">做过的几个东西，以及和它们相关的文章。</p>
  </header>

  <div class="projects">
    {withRelated.map((p) => (
      <article class="project">
        <h2 class="project-name">
          {p.name}
          {p.placeholder && <span class="badge">占位</span>}
        </h2>
        <p class="project-summary">{p.summary}</p>

        <div class="project-stack">
          {p.stack.map((s) => <span class="stack-item">{s}</span>)}
        </div>

        {p.links.length > 0 && (
          <div class="project-links">
            {p.links.map((l) => (
              <a href={l.href} target="_blank" rel="noopener">{l.label} →</a>
            ))}
          </div>
        )}

        {p.related.length > 0 && (
          <div class="project-related">
            <span class="related-label">相关文章</span>
            <ul>
              {p.related.map((post) => (
                <li><a href={`/posts/${post.id}/`}>{post.data.title}</a></li>
              ))}
            </ul>
          </div>
        )}
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 36px;
  }
  .page-title {
    font-size: 1.7rem;
    margin: 0 0 6px;
  }
  .page-sub {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }
  .projects {
    display: flex;
    flex-direction: column;
  }
  .project {
    padding-block: 28px;
    border-bottom: 1px solid var(--border);
  }
  .project:last-child {
    border-bottom: none;
  }
  .project-name {
    font-size: 1.2rem;
    font-family: var(--font-mono);
    margin: 0 0 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .badge {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 7px;
  }
  .project-summary {
    margin: 0 0 14px;
    color: var(--text);
    line-height: 1.75;
  }
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 14px;
  }
  .stack-item {
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--code-bg);
    border-radius: 4px;
    padding: 3px 9px;
  }
  .project-links {
    display: flex;
    gap: 18px;
    font-size: 0.9rem;
    margin-bottom: 14px;
  }
  .project-related {
    font-size: 0.9rem;
  }
  .related-label {
    color: var(--muted);
    font-size: 0.82rem;
  }
  .project-related ul {
    list-style: none;
    margin: 6px 0 0;
    padding: 0;
  }
  .project-related li {
    padding-block: 3px;
  }
</style>
