---
interface Props {
  tag: string;
  count?: number;
}
const { tag, count } = Astro.props;
---

<a class="tag" href={`/tags/${tag}/`}>
  <span class="tag-hash">#</span>{tag}{count !== undefined && <span class="tag-count">{count}</span>}
</a>

<style>
  .tag {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.6;
    white-space: nowrap;
  }
  .tag:hover {
    color: var(--link);
    text-decoration: none;
  }
  .tag-hash {
    color: var(--border);
  }
  .tag:hover .tag-hash {
    color: var(--link);
  }
  .tag-count {
    margin-left: 4px;
    color: var(--border);
    font-variant-numeric: tabular-nums;
  }
</style>
