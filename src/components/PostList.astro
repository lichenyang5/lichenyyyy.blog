---
import type { Post } from '../utils/posts';
import { readingTime } from '../utils/posts';
import { formatDate, toISODate } from '../utils/date';
import Tag from './Tag.astro';

interface Props {
  posts: Post[];
  /** 是否显示摘要（首页可关掉以更紧凑，列表页默认开） */
  showDescription?: boolean;
}
const { posts, showDescription = true } = Astro.props;
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li class="post-item">
        <h2 class="post-title">
          <a href={`/posts/${post.id}/`}>{post.data.title}</a>
        </h2>
        {showDescription && post.data.description && (
          <p class="post-desc">{post.data.description}</p>
        )}
        <div class="post-foot">
          <div class="post-meta">
            <time datetime={toISODate(post.data.date)}>{formatDate(post.data.date)}</time>
            <span class="dot">·</span>
            <span>{post.data.category}</span>
            <span class="dot">·</span>
            <span>{readingTime(post.body)} 分钟</span>
          </div>
          {post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <Tag tag={tag} />
              ))}
            </div>
          )}
        </div>
      </li>
    ))
  }
</ul>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-item {
    padding-block: 28px;
    border-bottom: 1px solid var(--border);
  }
  .post-item:first-child {
    padding-top: 4px;
  }
  .post-item:last-child {
    border-bottom: none;
  }
  .post-title {
    margin: 0;
    font-size: 1.2rem; /* ~19px */
    font-weight: 650;
    line-height: 1.45;
  }
  .post-title a {
    color: var(--text);
    transition: color 0.15s ease;
  }
  .post-title a:hover {
    color: var(--link);
    text-decoration: none;
  }
  .post-desc {
    margin: 9px 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  /* meta + 标签放在底部一行，掘金式的轻量信息行 */
  .post-foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-top: 12px;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
  }
  .dot {
    color: var(--border);
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
